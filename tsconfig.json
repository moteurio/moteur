{
    "files": [],
    "references": [
        { "path": "packages/types" },
        { "path": "packages/core" },
        { "path": "packages/plugin-sdk" },
        { "path": "packages/api" },
        { "path": "packages/presence" },
        { "path": "packages/ai" }
    ],
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "composite": true,
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@moteurio/types/*": ["packages/types/dist/*"],
            "@moteurio/core/*": ["packages/core/dist/*"],
            "@moteurio/api/*": ["packages/api/dist/*"],
            "@moteurio/presence/*": ["packages/presence/dist/*"],
            "@moteurio/plugin-sdk/*": ["packages/plugin-sdk/dist/*"],
            "@moteurio/ai/*": ["packages/ai/dist/*"],
            "@moteurio/types": ["packages/types/dist"],
            "@moteurio/core": ["packages/core/dist"],
            "@moteurio/api": ["packages/api/dist"],
            "@moteurio/plugin-sdk": ["packages/plugin-sdk/dist"],
            "@moteurio/presence": ["packages/presence/dist"],
            "@moteurio/ai": ["packages/ai/dist"]
        },
        "outDir": "dist"
    },
    "include": ["src"]
}
