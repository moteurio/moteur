{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@moteurio/types": ["../types/dist/index.d.ts"]
        }
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "dist"],
    "references": [{ "path": "../types" }]
}
