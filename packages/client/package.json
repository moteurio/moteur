{
    "name": "@moteurio/client",
    "version": "2026.3.27",
    "description": "JavaScript/TypeScript client for the Moteur REST API",
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "ARCHITECTURE.md",
        "CONTRIBUTING.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/moteurio/moteur.git",
        "directory": "packages/client"
    },
    "homepage": "https://github.com/moteurio/moteur/tree/main/packages/client#readme",
    "bugs": {
        "url": "https://github.com/moteurio/moteur/issues"
    },
    "engines": {
        "node": ">=22"
    },
    "keywords": [
        "moteur",
        "cms",
        "headless",
        "api",
        "client",
        "content-engine"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -b",
        "clean": "rimraf dist",
        "prepublishOnly": "pnpm run build",
        "lint": "eslint . --ext .ts",
        "test": "vitest run",
        "test:watch": "vitest"
    },
    "dependencies": {
        "@moteurio/types": "workspace:*",
        "axios": "^1.7.0"
    },
    "devDependencies": {
        "@types/node": "^22.0.0",
        "@vitest/coverage-v8": "4.1.2",
        "rimraf": "^5.0.0",
        "typescript": "^5.4.0",
        "vitest": "^3.2.4"
    },
    "license": "MIT"
}
