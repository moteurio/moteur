{
    "name": "@moteurio/ai",
    "version": "2026.3.28",
    "description": "AI layer for Moteur: providers, credits, translation, generation",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/moteurio/moteur.git",
        "directory": "packages/ai"
    },
    "homepage": "https://github.com/moteurio/moteur/tree/main/packages/ai#readme",
    "bugs": {
        "url": "https://github.com/moteurio/moteur/issues"
    },
    "keywords": [
        "moteur",
        "cms",
        "ai",
        "headless",
        "content-engine"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "tsc -b",
        "clean": "rimraf dist",
        "test": "vitest run",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "prepublishOnly": "pnpm run test && pnpm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@moteurio/core": "workspace:*",
        "@moteurio/types": "workspace:*",
        "axios": "^1.14.0",
        "express": "^4.19.2",
        "linkedom": "^0.18.0",
        "openapi-types": "^12.1.3",
        "zod": "^4.0.5"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/node": "^22.10.0",
        "@vitest/coverage-v8": "4.1.2",
        "@types/supertest": "^6.0.3",
        "supertest": "^7.2.0",
        "typescript": "^5.4.5"
    }
}
