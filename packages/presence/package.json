{
    "name": "@moteurio/presence",
    "version": "2026.3.29",
    "description": "Socket.IO presence, exclusive field locks, and ephemeral per-screen LWW state for Moteur Studio",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/moteurio/moteur.git",
        "directory": "packages/presence"
    },
    "homepage": "https://github.com/moteurio/moteur/tree/main/packages/presence#readme",
    "bugs": {
        "url": "https://github.com/moteurio/moteur/issues"
    },
    "keywords": [
        "moteur",
        "cms",
        "socket.io",
        "presence",
        "collaboration",
        "content-engine"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "tsc -b",
        "clean": "rimraf dist",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "test": "vitest run",
        "prepublishOnly": "pnpm run test && pnpm run build"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@moteurio/core": "workspace:*",
        "@moteurio/types": "workspace:*",
        "express": "^4.19.2",
        "jsonwebtoken": "^9.0.2",
        "openapi-types": "^12.1.3",
        "socket.io": "^4.8.1"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/socket.io": "^3.0.2",
        "@vitest/coverage-v8": "4.1.2"
    }
}
