{
    "name": "@moteurio/api",
    "version": "2026.3.27",
    "description": "Express REST API for Moteur: admin, public collections, OpenAPI, webhooks",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "type": "module",
    "exports": {
        ".": "./dist/index.js",
        "./*": "./dist/*"
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/moteurio/moteur.git",
        "directory": "packages/api"
    },
    "homepage": "https://github.com/moteurio/moteur/tree/main/packages/api#readme",
    "bugs": {
        "url": "https://github.com/moteurio/moteur/issues"
    },
    "keywords": [
        "moteur",
        "cms",
        "headless",
        "rest",
        "openapi",
        "content-engine"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "build": "tsc -b",
        "clean": "rimraf dist",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "test": "node scripts/check-no-plugin-import-leaks.mjs && vitest run",
        "prepublishOnly": "pnpm run test && pnpm run build",
        "openapi:export": "tsx scripts/export-openapi.ts",
        "openapi:check-responses": "tsx scripts/check-openapi-responses.ts"
    },
    "publishConfig": {
        "access": "public"
    },
    "dependencies": {
        "@moteurio/ai": "workspace:*",
        "@moteurio/core": "workspace:*",
        "@moteurio/plugin-sdk": "workspace:*",
        "@moteurio/presence": "workspace:*",
        "@moteurio/types": "workspace:*",
        "@scalar/express-api-reference": "^0.9.3",
        "axios": "^1.14.0",
        "cors": "^2.8.5",
        "dotenv": "^16.5.0",
        "express": "^4.19.2",
        "express-rate-limit": "^7.4.1",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.2",
        "multer": "^2.1.1",
        "openapi-types": "^12.1.3",
        "zod": "^4.0.5"
    },
    "license": "MIT",
    "devDependencies": {
        "@types/express": "^5.0.3",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.10.0",
        "@vitest/coverage-v8": "4.1.2",
        "tsx": "^4.21.0"
    }
}
